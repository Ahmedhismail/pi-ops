# pi-ops configuration
# Copy to ~/.pi-config.env or ./pi-config.env and fill in values.
# ~/.pi-config.env is loaded first, then ./pi-config.env overrides.

# Default GPU type (run: prime availability gpu-types --output json)
PI_DEFAULT_GPU=A100_80GB

# Number of GPUs
PI_DEFAULT_GPU_COUNT=1

# Disk size in GB
PI_DEFAULT_DISK_SIZE=200

# Docker image (ubuntu_22_cuda_12 is the non-interactive default; override if needed)
PI_IMAGE=ubuntu_22_cuda_12

# Git repo to clone on the pod
PI_REPO_URL=  # e.g. git@github.com:user/repo.git

# Branch to checkout
PI_REPO_BRANCH=main

# Command to run after cloning
PI_SETUP_CMD="bash setup.sh"

# Local .env file to copy to the pod (relative to repo root)
PI_ENV_FILE=.env

# Where to store the active pod session ID
PI_SESSION_FILE=~/.pi-session

# Path to the bootstrap script (relative to pi-ops repo)
PI_BOOTSTRAP_SCRIPT=pods/pi-bootstrap.sh
